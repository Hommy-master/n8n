# ==========================================
# n8n 基础配置
# ==========================================

# 访问端口（默认 5678）
N8N_PORT=5678

# 基础认证（首次登录用）
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# 加密密钥（重要！用于加密凭据，请设置强密码并备份）
N8N_ENCRYPTION_KEY=2zUrbKnwXUKfMjXql3T5EP9Etsio1PkK

# 时区
GENERIC_TIMEZONE=Asia/Shanghai

# ==========================================
# 域名配置（用于 Webhook 和外部访问）
# ==========================================

# 你的域名或 IP
N8N_HOST=localhost
N8N_PROTOCOL=http

# Webhook 完整 URL（重要！外部服务回调用）
# 如果是本地使用，保持默认；如果有公网域名，填写完整 URL
# 例如：https://n8n.yourdomain.com/
WEBHOOK_URL=http://localhost:5678/

# Webhook 服务端口（可选，分离 webhook 时使用）
N8N_WEBHOOK_PORT=5679

# ==========================================
# PostgreSQL 数据库配置
# ==========================================

POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_2zUrbKnwXU
POSTGRES_DB=n8n

# ==========================================
# 高级配置（可选）
# ==========================================

# 执行超时时间（秒）
EXECUTIONS_TIMEOUT=3600

# 并发限制
N8N_CONCURRENCY_PRODUCTION_LIMIT=10